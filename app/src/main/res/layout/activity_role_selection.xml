<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FFF5E9">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KalaSetu"
        android:textSize="34sp"
        android:textStyle="bold"
        android:textColor="#A0522D"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connecting Artisans to the Digital World"
        android:textSize="16sp"
        android:textColor="#5D4037"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnCustomer"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Customer Login"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:layout_marginTop="40dp"
        android:backgroundTint="#BF6D30"/>

    <Button
        android:id="@+id/btnArtisan"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Artisan Login"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:layout_marginTop="18dp"
        android:backgroundTint="#8D5524"/>

    <Button
        android:id="@+id/btnAdmin"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Admin Dashboard"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:layout_marginTop="18dp"
        android:backgroundTint="#8D5524"/>
</LinearLayout>